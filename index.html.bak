const ALL_TOOLS = TOOLS;

function formatINR(n) {
  if (isNaN(n)) return '—';
  if (n >= 10000000) return '₹' + (n/10000000).toFixed(2) + ' Cr';
  if (n >= 100000) return '₹' + (n/100000).toFixed(2) + ' L';
  return '₹' + Math.round(n).toLocaleString('en-IN');
}

function goHome() {
  document.getElementById('home-view').style.display = 'block';
  document.getElementById('tool-view').style.display = 'none';
  document.getElementById('allcalc-view').style.display = 'none';
  document.getElementById('nav-all-btn').classList.remove('active');
  window.scrollTo(0,0);
}

function goAllCalc() {
  document.getElementById('home-view').style.display = 'none';
  document.getElementById('tool-view').style.display = 'none';
  document.getElementById('allcalc-view').style.display = 'block';
  document.getElementById('nav-all-btn').classList.add('active');
  renderAllCalc();
  window.scrollTo(0,0);
}

const CAT_META = {
  finance:     { label: 'Finance',        icon: '💰', color: '#E8591A', desc: 'SIP, EMI, GST, Salary, FD, PPF, Tax & more' },
  realestate:  { label: 'Real Estate',    icon: '🏗️', color: '#16A34A', desc: 'Stamp Duty, EMI, Construction Cost, Bigha, Rent vs Buy' },
  academic:    { label: 'Academic',       icon: '🎓', color: '#2563EB', desc: 'CGPA, GPA, Attendance, Speed, BMI, Roman Numerals' },
  lifestyle:   { label: 'Lifestyle',      icon: '🌿', color: '#0891B2', desc: 'Fuel, Calories, Sleep, Water, Electricity, Pregnancy' },
  converters:  { label: 'Unit Converters',icon: '🔄', color: '#7C3AED', desc: 'Weight, Length, Temperature, Data, Currency, Area' }
};

function renderAllCalc() {
  const container = document.getElementById('allcalc-container');
  if (container.dataset.rendered) return; // only build once
  container.dataset.rendered = '1';

  const order = ['finance','realestate','academic','lifestyle','converters'];
  container.innerHTML = order.map(cat => {
    const meta = CAT_META[cat];
    const tools = TOOLS.filter(t => t.category === cat);
    const toolCards = tools.map(t => `
      <div class="acc-tool-card" style="--acc-color:${meta.color}" onclick="openToolFromAllCalc('${t.id}')">
        <div class="acc-tool-emoji">${t.icon}</div>
        <div class="acc-tool-info">
          <div class="acc-tool-name">${t.name}</div>
          <div class="acc-tool-desc">${t.desc}</div>
        </div>
      </div>`).join('');
    return `
      <div class="accordion" id="acc-${cat}">
        <div class="accordion-header" style="--acc-color:${meta.color}" onclick="toggleAccordion('${cat}')">
          <div class="acc-left">
            <span class="acc-icon">${meta.icon}</span>
            <div>
              <div style="display:flex;align-items:center;gap:0.4rem">
                <span class="acc-title">${meta.label}</span>
                <span class="acc-count">${tools.length} tools</span>
              </div>
              <div class="acc-desc">${meta.desc}</div>
            </div>
          </div>
          <span class="acc-chevron">▼</span>
        </div>
        <div class="accordion-body" id="acc-body-${cat}">
          <div class="acc-tools-grid">${toolCards}</div>
        </div>
      </div>`;
  }).join('');

  // Open finance by default
  toggleAccordion('finance');
}

function toggleAccordion(cat) {
  const header = document.querySelector(`#acc-${cat} .accordion-header`);
  const body = document.getElementById(`acc-body-${cat}`);
  const isOpen = body.classList.contains('open');
  header.classList.toggle('open', !isOpen);
  body.classList.toggle('open', !isOpen);
}

function openToolFromAllCalc(id) {
  document.getElementById('nav-all-btn').classList.remove('active');
  document.getElementById('allcalc-view').style.display = 'none';
  openTool(id);
}

function renderHomeTools(tools) {
  const c = document.getElementById('tools-container');
  c.innerHTML = tools.map(t => `
    <div class="tool-card" onclick="openTool('${t.id}')">
      <div class="tool-icon">${t.icon}</div>
      <div class="tool-name">${t.name}</div>
      <div class="tool-desc">${t.desc}</div>
    </div>`).join('');
}

function filterCategory(cat) {
  const filtered = TOOLS.filter(t => t.category === cat);
  renderHomeTools(filtered.length ? filtered : TOOLS);
  const sec = document.getElementById('featured-section');
  const names = { finance:'💰 Finance Tools', realestate:'🏗️ Real Estate Tools', academic:'🎓 Academic Tools', converters:'🔄 Unit Converters', lifestyle:'🌿 Lifestyle Tools' };
  sec.querySelector('.section-title').innerHTML = names[cat] || '⭐ Popular Tools <span class="pill-tag">Most Used</span>';
  sec.scrollIntoView({ behavior: 'smooth', block: 'start' });
}

function handleSearch(q) {
  const box = document.getElementById('search-results');
  if (!q.trim()) { box.style.display = 'none'; return; }
  const matches = ALL_TOOLS.filter(t => t.name.toLowerCase().includes(q.toLowerCase()) || t.desc.toLowerCase().includes(q.toLowerCase()));
  if (!matches.length) { box.style.display = 'none'; return; }
  box.innerHTML = matches.slice(0,6).map(t => `<div class="search-item" onmousedown="openTool('${t.id}')">${t.icon} ${t.name}<span class="search-cat">${t.category}</span></div>`).join('');
  box.style.display = 'block';
}

function openTool(id) {
  document.getElementById('search-results').style.display = 'none';
  document.getElementById('nav-search-input').value = '';
  const tool = TOOLS.find(t => t.id === id);
  if (!tool) { alert('Tool coming soon! 🚧'); return; }
  document.getElementById('home-view').style.display = 'none';
  document.getElementById('allcalc-view').style.display = 'none';
  document.getElementById('nav-all-btn').classList.remove('active');
  document.getElementById('tool-view').style.display = 'block';
  document.getElementById('tool-content').innerHTML = buildTool(tool);
  window.scrollTo(0,0);
  initTool(id);
}

function buildTool(t) {
  const affHtml = t.affiliate ? `<div class="affiliate-banner"><div class="aff-text">${t.affiliate.text} – zero charges to apply.</div><button class="aff-btn">${t.affiliate.btn}</button></div>` : '';
  const relHtml = t.related ? `<div class="section-title" style="margin-bottom:0.8rem">People Also Used</div><div class="related-grid">${t.related.map(rid => { const rt = ALL_TOOLS.find(x=>x.id===rid); return rt ? `<div class="related-card" onclick="openTool('${rt.id}')">${rt.icon} ${rt.name}</div>` : ''; }).join('')}</div>` : '';
  const faqHtml = t.faqs ? `<div class="seo-section"><h2>Frequently Asked Questions</h2>${t.faqs.map(f=>`<div class="faq-item"><div class="faq-q" onclick="toggleFaq(this)">${f.q}</div><div class="faq-a">${f.a}</div></div>`).join('')}</div>` : '';
  return `
    <div class="breadcrumb"><a onclick="goHome()">Home</a> › <a onclick="goHome()">${t.category.charAt(0).toUpperCase()+t.category.slice(1)}</a> › ${t.name}</div>
    <div class="tool-header"><h1>${t.icon} ${t.name}</h1><p>${t.desc}</p></div>
    ${affHtml}
    <div class="calculator-box" id="calc-box-${t.id}"><!-- inputs injected by initTool --></div>
    <div class="seo-section">
      <h2>How to Use This Calculator</h2>
      <p>${t.howto}</p>
      <div class="formula-box">${t.formula}</div>
    </div>
    ${faqHtml}
    ${relHtml}`;
}

function toggleFaq(el) { el.parentElement.classList.toggle('open'); }

