function resetTool(id) {
  const rb = document.getElementById(`${id}-result`);
  if (rb) rb.classList.remove('show');
}

// ---- CALCULATION LOGIC ----
function calcSIP() {
  const P = parseFloat(document.getElementById('sip-amt').value);
  const r = parseFloat(document.getElementById('sip-rate').value) / 100 / 12;
  const n = parseFloat(document.getElementById('sip-yrs').value) * 12;
  if (!P || !r || !n) return;
  const corpus = P * ((Math.pow(1+r, n) - 1) / r) * (1+r);
  const invested = P * n;
  const returns = corpus - invested;
  document.getElementById('sip-corpus').textContent = formatINR(corpus);
  document.getElementById('sip-invested').textContent = formatINR(invested);
  document.getElementById('sip-returns').textContent = formatINR(returns);
  document.getElementById('sip-mult').textContent = (corpus/invested).toFixed(2) + 'x';
  document.getElementById('sip-result').classList.add('show');
}
function calcGST() {
  const amt = parseFloat(document.getElementById('gst-amt').value);
  const rate = parseFloat(document.getElementById('gst-rate').value);
  const mode = document.getElementById('gst-mode').value;
  let base, tax, total;
  if (mode === 'add') { base = amt; tax = amt * rate / 100; total = base + tax; }
  else { total = amt; base = amt * 100 / (100 + rate); tax = total - base; }
  document.getElementById('gst-total').textContent = formatINR(total);
  document.getElementById('gst-base').textContent = formatINR(base);
  document.getElementById('gst-tax').textContent = formatINR(tax);
  document.getElementById('gst-cgst').textContent = formatINR(tax/2);
  document.getElementById('gst-sgst').textContent = formatINR(tax/2);
  document.getElementById('gst-result').classList.add('show');
}
function calcEMI() {
  const P = parseFloat(document.getElementById('emi-amt').value);
  const r = parseFloat(document.getElementById('emi-rate').value) / 100 / 12;
  const n = parseFloat(document.getElementById('emi-yrs').value) * 12;
  const emi = P * r * Math.pow(1+r,n) / (Math.pow(1+r,n)-1);
  const total = emi * n;
  const interest = total - P;
  document.getElementById('emi-emi').textContent = formatINR(emi);
  document.getElementById('emi-principal').textContent = formatINR(P);
  document.getElementById('emi-interest').textContent = formatINR(interest);
  document.getElementById('emi-total').textContent = formatINR(total);
  document.getElementById('emi-pct').textContent = ((interest/total)*100).toFixed(1) + '%';
  document.getElementById('emi-result').classList.add('show');
}
function calcSalary() {
  const ctc = parseFloat(document.getElementById('sal-ctc').value);
  const regime = document.getElementById('sal-regime').value;
  const basic = ctc * 0.40;
  const pf = basic * 0.12;
  const taxable = ctc - pf * 2 - 50000; // std deduction 50k
  let tax = 0;
  if (regime === 'new') {
    // 2025-26 new regime slabs
    if (taxable > 1500000) tax = (taxable-1500000)*0.30 + 150000*0.20 + 30000*0.15 + 30000*0.10 + 400000*0.05;
    else if (taxable > 1200000) tax = (taxable-1200000)*0.20 + 30000*0.15 + 30000*0.10 + 400000*0.05;
    else if (taxable > 1000000) tax = (taxable-1000000)*0.15 + 30000*0.10 + 400000*0.05;
    else if (taxable > 700000) tax = (taxable-700000)*0.10 + 400000*0.05;
    else if (taxable > 300000) tax = (taxable-300000)*0.05;
    if (taxable <= 700000) tax = 0; // rebate u/s 87A
    tax += tax * 0.04; // cess
  }
  const inHandAnnual = ctc - pf - Math.max(0,tax);
  const inHandMonthly = inHandAnnual / 12;
  document.getElementById('sal-inhand').textContent = formatINR(inHandMonthly);
  document.getElementById('sal-annual-ctc').textContent = formatINR(ctc);
  document.getElementById('sal-basic').textContent = formatINR(basic/12);
  document.getElementById('sal-pf').textContent = formatINR(pf/12);
  document.getElementById('sal-tax').textContent = formatINR(Math.max(0,tax));
  document.getElementById('salary-result').classList.add('show');
}
function calcFD() {
  const P = parseFloat(document.getElementById('fd-amt').value);
  const r = parseFloat(document.getElementById('fd-rate').value) / 100;
  const t = parseFloat(document.getElementById('fd-yrs').value);
  const n = parseFloat(document.getElementById('fd-freq').value);
  const A = P * Math.pow(1 + r/n, n*t);
  const interest = A - P;
  const effectiveYield = (Math.pow(1+r/n,n)-1)*100;
  document.getElementById('fd-maturity').textContent = formatINR(A);
  document.getElementById('fd-principal').textContent = formatINR(P);
  document.getElementById('fd-interest').textContent = formatINR(interest);
  document.getElementById('fd-yield').textContent = effectiveYield.toFixed(2) + '% p.a.';
  document.getElementById('fd-result').classList.add('show');
}
function calcCGPA() {
  const cgpa = parseFloat(document.getElementById('cgpa-val').value);
  const mult = parseFloat(document.getElementById('cgpa-formula').value);
  const pct = cgpa * mult;
  document.getElementById('cgpa-pct').textContent = pct.toFixed(2) + '%';
  document.getElementById('cgpa-in').textContent = cgpa;
  const grade = cgpa >= 9 ? 'O (Outstanding)' : cgpa >= 8 ? 'A+ (Excellent)' : cgpa >= 7 ? 'A (Very Good)' : cgpa >= 6 ? 'B+ (Good)' : cgpa >= 5 ? 'B (Above Avg)' : 'C (Average)';
  const cls = pct >= 75 ? 'First Class w/ Distinction' : pct >= 60 ? 'First Class' : pct >= 50 ? 'Second Class' : 'Pass Class';
  document.getElementById('cgpa-grade').textContent = grade;
  document.getElementById('cgpa-class').textContent = cls;
  document.getElementById('cgpa-result').classList.add('show');
}
function calcAttendance() {
  const total = parseInt(document.getElementById('att-total').value);
  const attended = parseInt(document.getElementById('att-attended').value);
  const req = parseFloat(document.getElementById('att-req').value) / 100;
  const pct = (attended / total * 100).toFixed(1);
  const safe = pct >= req * 100;
  document.getElementById('att-pct').textContent = pct + '%';
  document.getElementById('att-status').textContent = safe ? '✅ Safe' : '❌ Shortage';
  if (safe) {
    const canMiss = Math.floor((attended - req * total) / (1 - req));
    document.getElementById('att-action').textContent = 'Can miss ' + Math.max(0, canMiss) + ' more classes';
  } else {
    const needTotal = Math.ceil((req * total - attended) / (1 - req));
    document.getElementById('att-action').textContent = 'Must attend ' + needTotal + ' consecutive classes';
  }
  document.getElementById('attendance-result').classList.add('show');
}
function calcAge() {
  const dob = new Date(document.getElementById('age-dob').value);
  const ref = new Date(document.getElementById('age-ref').value);
  if (isNaN(dob) || isNaN(ref)) return;
  let yrs = ref.getFullYear() - dob.getFullYear();
  let mons = ref.getMonth() - dob.getMonth();
  let days = ref.getDate() - dob.getDate();
  if (days < 0) { mons--; days += new Date(ref.getFullYear(), ref.getMonth(), 0).getDate(); }
  if (mons < 0) { yrs--; mons += 12; }
  const totalDays = Math.floor((ref - dob) / 86400000);
  document.getElementById('age-val').textContent = yrs + ' yrs ' + mons + ' mos ' + days + ' days';
  document.getElementById('age-yrs').textContent = yrs;
  document.getElementById('age-months').textContent = mons;
  document.getElementById('age-days').textContent = days;
  document.getElementById('age-totaldays').textContent = totalDays.toLocaleString('en-IN');
  document.getElementById('age-result').classList.add('show');
}
const BIGHA_TO_SQFT = { bigha_up:26910.66, bigha_bih:27220, bigha_wb:14400, bigha_raj:27225, acre:43560, hectare:107639.1, sqft:1, sqmtr:10.7639, gaj:9 };
function calcBigha() {
  const val = parseFloat(document.getElementById('bigha-val').value);
  const from = document.getElementById('bigha-from').value;
  const to = document.getElementById('bigha-to').value;
  const sqft = val * BIGHA_TO_SQFT[from];
  const result = sqft / BIGHA_TO_SQFT[to];
  document.getElementById('bigha-out').textContent = result.toFixed(4) + ' ' + to.replace('_',' ').replace('bigha','Bigha').replace('sqft','sq ft').replace('sqmtr','sq m').replace('acre','Acres').replace('hectare','Hectares').replace('gaj','Gaj');
  document.getElementById('bigha-result').classList.add('show');
}
const UNIT_OPTS = {
  weight: { kg:1, g:1000, mg:1000000, lb:2.20462, oz:35.274, tola:85.7352, quintal:0.01 },
  length: { m:1, km:0.001, cm:100, mm:1000, ft:3.28084, inch:39.3701, yard:1.09361, mile:0.000621371 },
  temp: { celsius:1, fahrenheit:1, kelvin:1 }
};
function updateUnitOptions() {
  const cat = document.getElementById('unit-cat').value;
  const keys = Object.keys(UNIT_OPTS[cat]);
  const opts = keys.map(k => `<option value="${k}">${k.charAt(0).toUpperCase()+k.slice(1)}</option>`).join('');
  document.getElementById('unit-from').innerHTML = opts;
  document.getElementById('unit-to').innerHTML = opts;
  document.getElementById('unit-to').selectedIndex = 1;
}
function calcUnit() {
  const cat = document.getElementById('unit-cat').value;
  const from = document.getElementById('unit-from').value;
  const to = document.getElementById('unit-to').value;
  const val = parseFloat(document.getElementById('unit-val').value);
  let result;
  if (cat === 'temp') {
    let c = from==='fahrenheit'?(val-32)*5/9:from==='kelvin'?val-273.15:val;
    result = to==='fahrenheit'?c*9/5+32:to==='kelvin'?c+273.15:c;
  } else {
    const base = val / UNIT_OPTS[cat][from];
    result = base * UNIT_OPTS[cat][to];
  }
  document.getElementById('unit-out').textContent = result.toFixed(6).replace(/\.?0+$/, '') + ' ' + to;
  document.getElementById('unit-result').classList.add('show');
}
function calcLumpsum() {
  const P = parseFloat(document.getElementById('ls-amt').value);
  const r = parseFloat(document.getElementById('ls-rate').value) / 100;
  const n = parseFloat(document.getElementById('ls-yrs').value);
  const corpus = P * Math.pow(1 + r, n);
  const gains = corpus - P;
  document.getElementById('ls-corpus').textContent = formatINR(corpus);
  document.getElementById('ls-invested').textContent = formatINR(P);
  document.getElementById('ls-gains').textContent = formatINR(gains);
  document.getElementById('ls-mult').textContent = (corpus/P).toFixed(2) + 'x';
  document.getElementById('lumpsum-result').classList.add('show');
}
function calcFIRE() {
  const exp = parseFloat(document.getElementById('fire-exp').value);
  const inf = parseFloat(document.getElementById('fire-inf').value) / 100;
  const savings = parseFloat(document.getElementById('fire-savings').value);
  const sip = parseFloat(document.getElementById('fire-sip').value);
  const ret = parseFloat(document.getElementById('fire-ret').value) / 100;
  const annualExp = exp * 12;
  const corpus = annualExp * 25;
  const r = ret / 12;
  let balance = savings;
  let months = 0;
  while (balance < corpus && months < 600) { balance = balance * (1 + r) + sip; months++; }
  document.getElementById('fire-corpus').textContent = formatINR(corpus);
  document.getElementById('fire-yrs').textContent = months < 600 ? Math.ceil(months/12) + ' years' : '50+ years';
  document.getElementById('fire-annual').textContent = formatINR(annualExp);
  document.getElementById('fire-result').classList.add('show');
}
const STAMP_RATES = {
  mh: { male:6, female:5, joint:6, reg:1 },
  dl: { male:6, female:4, joint:5, reg:1 },
  up: { male:7, female:6, joint:7, reg:1 },
  ka: { male:5, female:5, joint:5, reg:1 },
  tn: { male:7, female:7, joint:7, reg:1 },
  wb: { male:6, female:6, joint:6, reg:1 },
  rj: { male:6, female:5, joint:5, reg:1 },
  gu: { male:4.9, female:4.9, joint:4.9, reg:1 },
  hr: { male:7, female:5, joint:6, reg:1 }
};
function calcStamp() {
  const val = parseFloat(document.getElementById('stamp-val').value);
  const state = document.getElementById('stamp-state').value;
  const buyer = document.getElementById('stamp-buyer').value;
  const rates = STAMP_RATES[state];
  const dutyPct = rates[buyer]; const regPct = rates.reg;
  const duty = val * dutyPct / 100;
  const reg = val * regPct / 100;
  const total = duty + reg;
  document.getElementById('stamp-total').textContent = formatINR(total);
  document.getElementById('stamp-duty').textContent = formatINR(duty) + ' (' + dutyPct + '%)';
  document.getElementById('stamp-reg').textContent = formatINR(reg) + ' (' + regPct + '%)';
  document.getElementById('stamp-rate').textContent = (dutyPct + regPct) + '% of property value';
  document.getElementById('stamp-result').classList.add('show');
}
const CON_RATES = {
  basic:   { tier3:1100, tier2:1400, tier1:1800 },
  standard:{ tier3:1500, tier2:1900, tier1:2400 },
  premium: { tier3:2000, tier2:2800, tier1:3600 },
  luxury:  { tier3:3000, tier2:4000, tier1:5500 }
};
function calcConstruction() {
  const area = parseFloat(document.getElementById('con-area').value);
  const quality = document.getElementById('con-quality').value;
  const city = document.getElementById('con-city').value;
  const rate = CON_RATES[quality][city];
  const total = area * rate;
  document.getElementById('con-total').textContent = formatINR(total);
  document.getElementById('con-rate').textContent = '₹' + rate.toLocaleString('en-IN') + '/sq ft';
  document.getElementById('con-civil').textContent = formatINR(total * 0.6);
  document.getElementById('con-finish').textContent = formatINR(total * 0.4);
  document.getElementById('construction-result').classList.add('show');
}
function addInvoiceItem() {
  const div = document.createElement('div');
  div.className = 'two-col inv-item';
  div.style.cssText = 'gap:0.4rem;margin-bottom:0.5rem';
  div.innerHTML = `<input type="text" placeholder="Item description" style="padding:0.5rem 0.75rem;border:1px solid var(--border);border-radius:7px;font-family:'DM Sans',sans-serif;font-size:0.85rem"><input type="number" placeholder="Qty" value="1" style="padding:0.5rem 0.75rem;border:1px solid var(--border);border-radius:7px;font-family:'DM Sans',sans-serif;font-size:0.85rem;max-width:80px"><input type="number" placeholder="Rate ₹" value="0" style="padding:0.5rem 0.75rem;border:1px solid var(--border);border-radius:7px;font-family:'DM Sans',sans-serif;font-size:0.85rem"><select style="padding:0.5rem 0.5rem;border:1px solid var(--border);border-radius:7px;font-family:'DM Sans',sans-serif;font-size:0.85rem"><option value="0">0% GST</option><option value="5">5%</option><option value="12">12%</option><option value="18" selected>18%</option><option value="28">28%</option></select>`;
  document.getElementById('inv-items').appendChild(div);
}
function calcInvoice() {
  const seller = document.getElementById('inv-seller').value || 'My Business';
  const gstin = document.getElementById('inv-gstin').value;
  const client = document.getElementById('inv-client').value || 'Client';
  const rows = document.querySelectorAll('#inv-items .inv-item');
  let items = [], subtotal = 0, totalGST = 0;
  rows.forEach(row => {
    const inputs = row.querySelectorAll('input, select');
    const desc = inputs[0].value || 'Item'; const qty = parseFloat(inputs[1].value)||1;
    const rate = parseFloat(inputs[2].value)||0; const gstRate = parseFloat(inputs[3].value)||0;
    const amount = qty * rate; const gst = amount * gstRate / 100;
    subtotal += amount; totalGST += gst;
    items.push({ desc, qty, rate, amount, gstRate, gst });
  });
  const grand = subtotal + totalGST;
  const today = new Date().toLocaleDateString('en-IN');
  const invNo = 'INV-' + Date.now().toString().slice(-6);
  document.getElementById('inv-preview').innerHTML = `
    <div style="border:1px solid rgba(255,255,255,0.2);border-radius:8px;padding:1rem;font-size:0.82rem">
      <div style="display:flex;justify-content:space-between;margin-bottom:0.8rem">
        <div><strong style="font-size:1rem">${seller}</strong>${gstin?'<br>GSTIN: '+gstin:''}</div>
        <div style="text-align:right;color:rgba(255,255,255,0.6)">Invoice: ${invNo}<br>Date: ${today}</div>
      </div>
      <div style="color:rgba(255,255,255,0.7);margin-bottom:0.8rem">Bill To: <strong style="color:#fff">${client}</strong></div>
      <table style="width:100%;border-collapse:collapse;font-size:0.78rem">
        <tr style="border-bottom:1px solid rgba(255,255,255,0.2);color:rgba(255,255,255,0.5)"><td style="padding:4px 0">Item</td><td style="text-align:right;padding:4px">Qty</td><td style="text-align:right;padding:4px">Rate</td><td style="text-align:right;padding:4px">GST</td><td style="text-align:right;padding:4px">Amount</td></tr>
        ${items.map(i=>`<tr><td style="padding:4px 0">${i.desc}</td><td style="text-align:right;padding:4px">${i.qty}</td><td style="text-align:right;padding:4px">₹${i.rate.toLocaleString('en-IN')}</td><td style="text-align:right;padding:4px">${i.gstRate}%</td><td style="text-align:right;padding:4px">₹${(i.amount+i.gst).toLocaleString('en-IN')}</td></tr>`).join('')}
        <tr style="border-top:1px solid rgba(255,255,255,0.2)"><td colspan="4" style="padding:6px 0;text-align:right;color:rgba(255,255,255,0.6)">Subtotal</td><td style="text-align:right;padding:6px 4px">₹${subtotal.toLocaleString('en-IN')}</td></tr>
        <tr><td colspan="4" style="text-align:right;padding:2px 0;color:rgba(255,255,255,0.6)">Total GST</td><td style="text-align:right;padding:2px 4px">₹${totalGST.toLocaleString('en-IN')}</td></tr>
        <tr><td colspan="4" style="text-align:right;padding:4px 0;font-weight:700;font-size:0.9rem">Grand Total</td><td style="text-align:right;padding:4px;font-weight:700;font-size:0.9rem;color:var(--saffron-mid)">₹${grand.toLocaleString('en-IN')}</td></tr>
      </table>
    </div>`;
  document.getElementById('invoice-result').classList.add('show');
}
function calcPPF() {
  const P = parseFloat(document.getElementById('ppf-amt').value);
  const r = parseFloat(document.getElementById('ppf-rate').value) / 100;
  const n = parseFloat(document.getElementById('ppf-yrs').value);
  let balance = 0;
  for (let y = 1; y <= n; y++) balance = (balance + P) * (1 + r);
  const invested = P * n;
  const interest = balance - invested;
  const taxSaved = P * 0.30 * n;
  document.getElementById('ppf-maturity').textContent = formatINR(balance);
  document.getElementById('ppf-invested').textContent = formatINR(invested);
  document.getElementById('ppf-interest').textContent = formatINR(interest);
  document.getElementById('ppf-taxsaved').textContent = formatINR(taxSaved);
  document.getElementById('ppf-result').classList.add('show');
}
function calcNewTax(income) {
  const std = 75000; let taxable = Math.max(0, income - std); let tax = 0;
  if (taxable <= 300000) tax = 0;
  else if (taxable <= 700000) tax = (taxable-300000)*0.05;
  else if (taxable <= 1000000) tax = 20000+(taxable-700000)*0.10;
  else if (taxable <= 1200000) tax = 50000+(taxable-1000000)*0.15;
  else if (taxable <= 1500000) tax = 80000+(taxable-1200000)*0.20;
  else tax = 140000+(taxable-1500000)*0.30;
  if (taxable <= 700000) tax = 0;
  return tax * 1.04;
}
function calcOldTax(income, d80c, d80d, hra, other) {
  const std = 50000; let taxable = Math.max(0, income - std - Math.min(d80c,150000) - Math.min(d80d,25000) - hra - other);
  let tax = 0;
  if (taxable <= 250000) tax = 0;
  else if (taxable <= 500000) tax = (taxable-250000)*0.05;
  else if (taxable <= 1000000) tax = 12500+(taxable-500000)*0.20;
  else tax = 112500+(taxable-1000000)*0.30;
  if (income <= 500000) tax = 0;
  return tax * 1.04;
}
function calcTax() {
  const income = parseFloat(document.getElementById('tax-income').value);
  const d80c = parseFloat(document.getElementById('tax-80c').value)||0;
  const d80d = parseFloat(document.getElementById('tax-80d').value)||0;
  const hra = parseFloat(document.getElementById('tax-hra').value)||0;
  const other = parseFloat(document.getElementById('tax-other').value)||0;
  const newTax = calcNewTax(income);
  const oldTax = calcOldTax(income, d80c, d80d, hra, other);
  const better = newTax <= oldTax ? 'New Regime' : 'Old Regime';
  const save = Math.abs(newTax - oldTax);
  document.getElementById('tax-rec').textContent = better + ' is Better';
  document.getElementById('tax-new').textContent = formatINR(newTax);
  document.getElementById('tax-old').textContent = formatINR(oldTax);
  document.getElementById('tax-save').textContent = formatINR(save);
  document.getElementById('tax-result').classList.add('show');
}
function updatePctInputs() {
  const type = document.getElementById('pct-type').value;
  const c = document.getElementById('pct-inputs');
  if (type === 'of') c.innerHTML = `<div class="two-col"><div class="form-row"><label>Percentage (%)</label><input type="number" id="pct-a" value="20"></div><div class="form-row"><label>Of Number</label><input type="number" id="pct-b" value="5000"></div></div>`;
  else if (type === 'change') c.innerHTML = `<div class="two-col"><div class="form-row"><label>Original / Old Value</label><input type="number" id="pct-a" value="100"></div><div class="form-row"><label>New Value</label><input type="number" id="pct-b" value="120"></div></div>`;
  else c.innerHTML = `<div class="two-col"><div class="form-row"><label>Value (X)</label><input type="number" id="pct-a" value="400"></div><div class="form-row"><label>Total (Y)</label><input type="number" id="pct-b" value="2000"></div></div>`;
}
function calcPercentage() {
  const type = document.getElementById('pct-type').value;
  const a = parseFloat(document.getElementById('pct-a').value);
  const b = parseFloat(document.getElementById('pct-b').value);
  let result, explain;
  if (type === 'of') { result = (a/100)*b; explain = a+'% of '+b.toLocaleString('en-IN')+' = '+result.toLocaleString('en-IN'); }
  else if (type === 'change') { result = ((b-a)/a)*100; explain = (result>0?'Increase':'Decrease')+' from '+a.toLocaleString('en-IN')+' to '+b.toLocaleString('en-IN')+' = '+Math.abs(result).toFixed(2)+'%'; }
  else { result = (a/b)*100; explain = a.toLocaleString('en-IN')+' is '+result.toFixed(2)+'% of '+b.toLocaleString('en-IN'); }
  document.getElementById('pct-out').textContent = type==='of' ? result.toLocaleString('en-IN') : result.toFixed(2)+'%';
  document.getElementById('pct-explain').textContent = explain;
  document.getElementById('percentage-result').classList.add('show');
}
function calcBMI() {
  const wt = parseFloat(document.getElementById('bmi-wt').value);
  const htCm = parseFloat(document.getElementById('bmi-ht').value);
  const ht = htCm / 100;
  const bmi = wt / (ht * ht);
  const getCat = (b, asian) => {
    if (asian) return b < 18.5?'Underweight':b < 23?'Normal':b < 27.5?'Overweight':'Obese';
    return b < 18.5?'Underweight':b < 25?'Normal':b < 30?'Overweight':'Obese';
  };
  const minWt = (18.5 * ht * ht).toFixed(1);
  const maxWt = ((asian => asian ? 23 : 24.9)(true) * ht * ht).toFixed(1);
  document.getElementById('bmi-val').textContent = bmi.toFixed(1);
  document.getElementById('bmi-cat').textContent = getCat(bmi, false);
  document.getElementById('bmi-catasia').textContent = getCat(bmi, true);
  document.getElementById('bmi-range').textContent = minWt + ' – ' + maxWt + ' kg';
  document.getElementById('bmi-result').classList.add('show');
}
function calcDiscount() {
  const mrp = parseFloat(document.getElementById('disc-mrp').value);
  const pct = parseFloat(document.getElementById('disc-pct').value);
  const gstRate = parseFloat(document.getElementById('disc-gst').value);
  const afterDisc = mrp * (1 - pct/100);
  const save = mrp - afterDisc;
  const gstAmt = afterDisc * gstRate / 100;
  const final = afterDisc + gstAmt;
  document.getElementById('disc-final').textContent = formatINR(final);
  document.getElementById('disc-save').textContent = formatINR(save) + ' (' + pct + '% off)';
  document.getElementById('disc-after').textContent = formatINR(afterDisc);
  document.getElementById('disc-gsamt').textContent = gstRate > 0 ? formatINR(gstAmt) + ' (' + gstRate + '%)' : 'None';
  document.getElementById('discount-result').classList.add('show');
}

function calcRD() {
  const R = parseFloat(document.getElementById('rd-amt').value);
  const rate = parseFloat(document.getElementById('rd-rate').value) / 100;
  const months = parseInt(document.getElementById('rd-months').value);
  const i = rate / 4; // quarterly rate
  let maturity = 0;
  for (let m = 0; m < months; m++) {
    const quartersLeft = (months - m) / 3;
    maturity += R * Math.pow(1 + i, quartersLeft);
  }
  const deposited = R * months;
  const interest = maturity - deposited;
  document.getElementById('rd-maturity').textContent = formatINR(maturity);
  document.getElementById('rd-deposited').textContent = formatINR(deposited);
  document.getElementById('rd-interest').textContent = formatINR(interest);
  document.getElementById('rd-yield').textContent = ((interest / deposited) * 100).toFixed(2) + '%';
  document.getElementById('rd-result').classList.add('show');
}
function calcCarLoan() {
  const price = parseFloat(document.getElementById('car-price').value);
  const down = parseFloat(document.getElementById('car-down').value);
  const months = parseInt(document.getElementById('car-months').value);
  const rate = parseFloat(document.getElementById('car-rate').value);
  const P = price - down;
  const r = rate / 100 / 12;
  const emi = P * r * Math.pow(1+r,months) / (Math.pow(1+r,months)-1);
  const totalInterest = emi * months - P;
  document.getElementById('car-emi').textContent = formatINR(emi);
  document.getElementById('car-loan').textContent = formatINR(P);
  document.getElementById('car-interest').textContent = formatINR(totalInterest);
  document.getElementById('car-total').textContent = formatINR(price + totalInterest);
  document.getElementById('carloan-result').classList.add('show');
}
function calcGold() {
  const wt = parseFloat(document.getElementById('gold-wt').value);
  const rate = parseFloat(document.getElementById('gold-rate').value);
  const purity = parseFloat(document.getElementById('gold-purity').value);
  const makingPct = parseFloat(document.getElementById('gold-making').value);
  const goldValue = wt * rate * purity;
  const makingCharge = goldValue * makingPct / 100;
  const gst = goldValue * 0.03 + makingCharge * 0.05;
  const total = goldValue + makingCharge + gst;
  document.getElementById('gold-total').textContent = formatINR(total);
  document.getElementById('gold-val').textContent = formatINR(goldValue);
  document.getElementById('gold-mc').textContent = formatINR(makingCharge);
  document.getElementById('gold-gst').textContent = formatINR(gst);
  document.getElementById('gold-result').classList.add('show');
}
function calcSI() {
  const P = parseFloat(document.getElementById('si-p').value);
  const R = parseFloat(document.getElementById('si-r').value);
  const T = parseFloat(document.getElementById('si-t').value);
  const si = P * R * T / 100;
  const amount = P + si;
  document.getElementById('si-amount').textContent = formatINR(amount);
  document.getElementById('si-interest').textContent = formatINR(si);
  document.getElementById('si-principal').textContent = formatINR(P);
  document.getElementById('si-monthly').textContent = formatINR(si / (T * 12));
  document.getElementById('si-result').classList.add('show');
}
function calcNPS() {
  const currentAge = parseInt(document.getElementById('nps-age').value);
  const monthly = parseFloat(document.getElementById('nps-sip').value);
  const ret = parseFloat(document.getElementById('nps-ret').value) / 100 / 12;
  const annuityRate = parseFloat(document.getElementById('nps-annuity').value) / 100;
  const months = (60 - currentAge) * 12;
  if (months <= 0) { alert('Age must be less than 60'); return; }
  const corpus = monthly * ((Math.pow(1+ret, months) - 1) / ret) * (1+ret);
  const lumpsum = corpus * 0.6;
  const annuityCorpus = corpus * 0.4;
  const pension = annuityCorpus * annuityRate / 12;
  document.getElementById('nps-corpus').textContent = formatINR(corpus);
  document.getElementById('nps-lumpsum').textContent = formatINR(lumpsum);
  document.getElementById('nps-annuityamt').textContent = formatINR(annuityCorpus);
  document.getElementById('nps-pension').textContent = formatINR(pension) + '/mo';
  document.getElementById('nps-result').classList.add('show');
}
function calcFuel() {
  const dist = parseFloat(document.getElementById('fuel-dist').value);
  const kmpl = parseFloat(document.getElementById('fuel-kmpl').value);
  const price = parseFloat(document.getElementById('fuel-price').value);
  const litres = dist / kmpl;
  const total = litres * price;
  const perkm = total / dist;
  document.getElementById('fuel-total').textContent = '₹' + total.toFixed(2);
  document.getElementById('fuel-litres').textContent = litres.toFixed(2) + ' L';
  document.getElementById('fuel-perkm').textContent = '₹' + perkm.toFixed(2);
  document.getElementById('fuel-per100').textContent = '₹' + (perkm * 100).toFixed(2);
  document.getElementById('fuel-result').classList.add('show');
}
function calcCalorie() {
  const wt = parseFloat(document.getElementById('cal-wt').value);
  const ht = parseFloat(document.getElementById('cal-ht').value);
  const age = parseInt(document.getElementById('cal-age').value);
  const gender = document.getElementById('cal-gender').value;
  const activity = parseFloat(document.getElementById('cal-activity').value);
  const bmr = gender === 'male' ? 10*wt + 6.25*ht - 5*age + 5 : 10*wt + 6.25*ht - 5*age - 161;
  const tdee = bmr * activity;
  document.getElementById('cal-tdee').textContent = Math.round(tdee) + ' kcal/day';
  document.getElementById('cal-bmr').textContent = Math.round(bmr) + ' kcal';
  document.getElementById('cal-lose').textContent = Math.round(tdee - 500) + ' kcal/day';
  document.getElementById('cal-gain').textContent = Math.round(tdee + 300) + ' kcal/day';
  document.getElementById('calorie-result').classList.add('show');
}
function updateSpeedInputs() {
  const find = document.getElementById('spd-find').value;
  const c = document.getElementById('spd-inputs');
  if (find === 'speed') c.innerHTML = `<div class="two-col"><div class="form-row"><label>Distance (km)</label><input type="number" id="spd-a" value="100" min="0.1"></div><div class="form-row"><label>Time (hours)</label><input type="number" id="spd-b" value="2" step="0.5" min="0.1"></div></div>`;
  else if (find === 'distance') c.innerHTML = `<div class="two-col"><div class="form-row"><label>Speed (km/h)</label><input type="number" id="spd-a" value="60" min="1"></div><div class="form-row"><label>Time (hours)</label><input type="number" id="spd-b" value="2" step="0.5" min="0.1"></div></div>`;
  else c.innerHTML = `<div class="two-col"><div class="form-row"><label>Distance (km)</label><input type="number" id="spd-a" value="100" min="0.1"></div><div class="form-row"><label>Speed (km/h)</label><input type="number" id="spd-b" value="60" min="1"></div></div>`;
}
function calcSpeed() {
  const find = document.getElementById('spd-find').value;
  const a = parseFloat(document.getElementById('spd-a').value);
  const b = parseFloat(document.getElementById('spd-b').value);
  let outText, extras = '';
  if (find === 'speed') {
    const spd = a / b;
    outText = spd.toFixed(2) + ' km/h';
    extras = `<div class="result-item"><div class="result-item-label">In m/s</div><div class="result-item-val">${(spd*1000/3600).toFixed(3)} m/s</div></div><div class="result-item"><div class="result-item-label">Distance</div><div class="result-item-val">${a} km</div></div>`;
  } else if (find === 'distance') {
    const dist = a * b;
    outText = dist.toFixed(2) + ' km';
    extras = `<div class="result-item"><div class="result-item-label">In meters</div><div class="result-item-val">${(dist*1000).toLocaleString('en-IN')} m</div></div>`;
  } else {
    const time = a / b;
    const hrs = Math.floor(time);
    const mins = Math.round((time - hrs) * 60);
    outText = time.toFixed(2) + ' hours';
    extras = `<div class="result-item"><div class="result-item-label">In Hours & Mins</div><div class="result-item-val">${hrs}h ${mins}m</div></div>`;
  }
  document.getElementById('spd-out').textContent = outText;
  document.getElementById('spd-extras').innerHTML = extras;
  document.getElementById('speed-result').classList.add('show');
}
function calcNumBase() {
  const input = document.getElementById('nb-input').value.trim().toUpperCase();
  const fromBase = parseInt(document.getElementById('nb-from').value);
  const decimal = parseInt(input, fromBase);
  if (isNaN(decimal) || decimal < 0) { alert('Invalid number for selected base. Check your input.'); return; }
  document.getElementById('nb-dec').textContent = decimal.toString(10);
  document.getElementById('nb-bin').textContent = decimal.toString(2);
  document.getElementById('nb-oct').textContent = decimal.toString(8);
  document.getElementById('nb-hex').textContent = decimal.toString(16).toUpperCase();
  document.getElementById('numbase-result').classList.add('show');
}
function calcData() {
  const val = parseFloat(document.getElementById('data-val').value);
  const unit = document.getElementById('data-from').value;
  const bytesMap = { b: 1, kb: 1024, mb: 1024**2, gb: 1024**3, tb: 1024**4, mbit: 1024**2/8, gbit: 1024**3/8 };
  const bytes = val * bytesMap[unit];
  const fmt = n => {
    if (n >= 1e12) return (n/1e12).toFixed(4) + '';
    if (n >= 1) return n.toLocaleString('en-IN', {maximumFractionDigits: 4});
    return n.toExponential(3);
  };
  document.getElementById('data-main-gb').textContent = fmt(bytes / 1024**3) + ' GB';
  document.getElementById('data-bytes').textContent = fmt(bytes) + ' B';
  document.getElementById('data-kb').textContent = fmt(bytes / 1024) + ' KB';
  document.getElementById('data-mb').textContent = fmt(bytes / 1024**2) + ' MB';
  document.getElementById('data-gb').textContent = fmt(bytes / 1024**3) + ' GB';
  document.getElementById('data-tb').textContent = fmt(bytes / 1024**4) + ' TB';
  document.getElementById('data-mbit').textContent = fmt(bytes * 8 / 1024**2) + ' Mb';
  document.getElementById('data-result').classList.add('show');
}


function calcPersonalLoan() {
  const P = parseFloat(document.getElementById('pl-amt').value);
  const r = parseFloat(document.getElementById('pl-rate').value) / 100 / 12;
  const n = parseInt(document.getElementById('pl-months').value);
  const emi = P * r * Math.pow(1+r,n) / (Math.pow(1+r,n)-1);
  const total = emi * n;
  const interest = total - P;
  document.getElementById('pl-emi').textContent = formatINR(emi);
  document.getElementById('pl-interest').textContent = formatINR(interest);
  document.getElementById('pl-total').textContent = formatINR(total);
  document.getElementById('pl-pct').textContent = ((interest/total)*100).toFixed(1) + '%';
  document.getElementById('personalloan-result').classList.add('show');
}
function calcHRA() {
  const basic = parseFloat(document.getElementById('hra-basic').value) * 12;
  const received = parseFloat(document.getElementById('hra-received').value) * 12;
  const rent = parseFloat(document.getElementById('hra-rent').value) * 12;
  const metro = document.getElementById('hra-city').value === 'metro';
  const l1 = received;
  const l2 = basic * (metro ? 0.5 : 0.4);
  const l3 = Math.max(0, rent - basic * 0.1);
  const exempt = Math.min(l1, l2, l3);
  const taxable = received - exempt;
  document.getElementById('hra-exempt').textContent = formatINR(exempt);
  document.getElementById('hra-taxable').textContent = formatINR(taxable);
  document.getElementById('hra-l1').textContent = formatINR(l1);
  document.getElementById('hra-l2').textContent = formatINR(l2) + (metro ? ' (50%)' : ' (40%)');
  document.getElementById('hra-l3').textContent = formatINR(l3);
  document.getElementById('hra-result').classList.add('show');
}
function calcGratuity() {
  const basic = parseFloat(document.getElementById('grat-basic').value);
  const years = parseFloat(document.getElementById('grat-years').value);
  const gratuity = basic * 15 * Math.floor(years) / 26;
  const eligible = years >= 5;
  const taxFreeLimit = 2000000;
  const taxable = Math.max(0, gratuity - taxFreeLimit);
  document.getElementById('grat-amount').textContent = eligible ? formatINR(gratuity) : '₹0 (Not eligible yet)';
  document.getElementById('grat-eligible').textContent = eligible ? '✅ Eligible (5+ yrs)' : `❌ Need ${(5-years).toFixed(1)} more years`;
  document.getElementById('grat-taxable').textContent = taxable > 0 ? formatINR(taxable) : 'Nil (within ₹20L limit)';
  document.getElementById('gratuity-result').classList.add('show');
}
function calcCAGR() {
  const start = parseFloat(document.getElementById('cagr-start').value);
  const end = parseFloat(document.getElementById('cagr-end').value);
  const years = parseFloat(document.getElementById('cagr-years').value);
  const cagr = (Math.pow(end/start, 1/years) - 1) * 100;
  const absReturn = ((end-start)/start)*100;
  const doublingYears = 72 / cagr;
  document.getElementById('cagr-out').textContent = cagr.toFixed(2) + '% p.a.';
  document.getElementById('cagr-abs').textContent = absReturn.toFixed(1) + '%';
  document.getElementById('cagr-gain').textContent = formatINR(end - start);
  document.getElementById('cagr-double').textContent = doublingYears.toFixed(1) + ' years (Rule of 72)';
  document.getElementById('cagr-result').classList.add('show');
}
function calcInflation() {
  const amt = parseFloat(document.getElementById('inf-amt').value);
  const rate = parseFloat(document.getElementById('inf-rate').value) / 100;
  const years = parseInt(document.getElementById('inf-years').value);
  const mode = document.getElementById('inf-mode').value;
  let result, loss;
  if (mode === 'future') {
    result = amt * Math.pow(1+rate, years);
    loss = result - amt;
    document.getElementById('inf-out').textContent = formatINR(result);
  } else {
    result = amt / Math.pow(1+rate, years);
    loss = amt - result;
    document.getElementById('inf-out').textContent = formatINR(result);
  }
  document.getElementById('inf-rate-out').textContent = (rate*100) + '% p.a.';
  document.getElementById('inf-period').textContent = years + ' years';
  document.getElementById('inf-loss').textContent = formatINR(loss);
  document.getElementById('inflation-result').classList.add('show');
}
function calcRentVsBuy() {
  const price = parseFloat(document.getElementById('rvb-price').value);
  const down = parseFloat(document.getElementById('rvb-down').value);
  const loanRate = parseFloat(document.getElementById('rvb-loanrate').value) / 100 / 12;
  const rent = parseFloat(document.getElementById('rvb-rent').value);
  const appre = parseFloat(document.getElementById('rvb-appre').value) / 100;
  const years = parseInt(document.getElementById('rvb-years').value);
  const months = years * 12;
  const loan = price - down;
  const emi = loan * loanRate * Math.pow(1+loanRate,months) / (Math.pow(1+loanRate,months)-1);
  const totalBuy = down + emi * months;
  // Rent with 5% annual escalation
  let totalRent = 0; let r = rent;
  for (let y = 0; y < years; y++) { totalRent += r * 12; r *= 1.05; }
  const propVal = price * Math.pow(1+appre, years);
  const netBuy = totalBuy - (propVal - price);
  const verdict = netBuy < totalRent ? 'Buying is Better 🏠' : 'Renting is Better 🏢';
  document.getElementById('rvb-verdict').textContent = verdict;
  document.getElementById('rvb-buycost').textContent = formatINR(totalBuy);
  document.getElementById('rvb-rentcost').textContent = formatINR(totalRent);
  document.getElementById('rvb-propval').textContent = formatINR(propVal);
  document.getElementById('rvb-netbuy').textContent = formatINR(netBuy);
  document.getElementById('rentvsbuy-result').classList.add('show');
}
function calcCI() {
  const P = parseFloat(document.getElementById('ci-p').value);
  const r = parseFloat(document.getElementById('ci-r').value) / 100;
  const t = parseFloat(document.getElementById('ci-t').value);
  const n = parseInt(document.getElementById('ci-freq').value);
  const A = P * Math.pow(1+r/n, n*t);
  const ci = A - P;
  const si = P * r * t;
  const ear = (Math.pow(1+r/n, n) - 1) * 100;
  document.getElementById('ci-amount').textContent = formatINR(A);
  document.getElementById('ci-ci').textContent = formatINR(ci);
  document.getElementById('ci-si').textContent = formatINR(si);
  document.getElementById('ci-adv').textContent = formatINR(ci - si) + ' more';
  document.getElementById('ci-ear').textContent = ear.toFixed(3) + '% p.a.';
  document.getElementById('compound-result').classList.add('show');
}
function addGPARow() {
  const c = document.getElementById('gpa-subjects');
  const n = c.children.length + 1;
  const div = document.createElement('div');
  div.className = 'two-col gpa-row';
  div.style.cssText = 'gap:0.4rem;margin-bottom:0.5rem';
  div.innerHTML = `<input type="text" placeholder="Subject ${n}" value="Subject ${n}" style="padding:0.5rem 0.75rem;border:1px solid var(--border);border-radius:7px;font-family:'DM Sans',sans-serif;font-size:0.85rem"><input type="number" placeholder="Marks /100" value="75" min="0" max="100" style="padding:0.5rem 0.75rem;border:1px solid var(--border);border-radius:7px;font-family:'DM Sans',sans-serif;font-size:0.85rem;max-width:100px"><input type="number" placeholder="Credits" value="4" min="1" max="8" style="padding:0.5rem 0.75rem;border:1px solid var(--border);border-radius:7px;font-family:'DM Sans',sans-serif;font-size:0.85rem;max-width:80px">`;
  c.appendChild(div);
}
function marksToGradePoint(marks) {
  if (marks >= 90) return 10; if (marks >= 80) return 9; if (marks >= 70) return 8;
  if (marks >= 60) return 7; if (marks >= 50) return 6; if (marks >= 45) return 5;
  if (marks >= 40) return 4; return 0;
}
function calcGPA() {
  const rows = document.querySelectorAll('.gpa-row');
  let totalPoints = 0, totalCredits = 0;
  rows.forEach(row => {
    const inputs = row.querySelectorAll('input');
    const marks = parseFloat(inputs[1].value) || 0;
    const credits = parseFloat(inputs[2].value) || 0;
    totalPoints += marksToGradePoint(marks) * credits;
    totalCredits += credits;
  });
  if (!totalCredits) return;
  const gpa = totalPoints / totalCredits;
  const pct = gpa * 9.5;
  const grade = gpa >= 9 ? 'O (Outstanding)' : gpa >= 8 ? 'A+ (Excellent)' : gpa >= 7 ? 'A (Very Good)' : gpa >= 6 ? 'B+ (Good)' : gpa >= 5 ? 'B (Above Avg)' : 'C / Pass';
  document.getElementById('gpa-out').textContent = gpa.toFixed(2);
  document.getElementById('gpa-pct').textContent = pct.toFixed(2) + '%';
  document.getElementById('gpa-grade').textContent = grade;
  document.getElementById('gpa-credits').textContent = totalCredits;
  document.getElementById('gpa-result').classList.add('show');
}
function addSGPARow() {
  const c = document.getElementById('sgpa-semesters');
  const n = c.children.length + 1;
  const div = document.createElement('div');
  div.className = 'two-col sgpa-row';
  div.style.cssText = 'gap:0.4rem;margin-bottom:0.5rem';
  div.innerHTML = `<div style="padding:0.5rem 0.75rem;font-size:0.85rem;color:var(--muted)">Semester ${n}</div><input type="number" placeholder="SGPA" value="8.0" min="0" max="10" step="0.01" style="padding:0.5rem 0.75rem;border:1px solid var(--border);border-radius:7px;font-family:'DM Sans',sans-serif;font-size:0.85rem;max-width:120px">`;
  c.appendChild(div);
}
function calcSGPA() {
  const rows = document.querySelectorAll('.sgpa-row');
  let total = 0, count = 0;
  rows.forEach(row => { const inp = row.querySelector('input'); if (inp) { total += parseFloat(inp.value)||0; count++; } });
  if (!count) return;
  const cgpa = total / count;
  const pct = cgpa * 9.5;
  const cls = pct >= 75 ? 'First Class w/ Distinction' : pct >= 60 ? 'First Class' : pct >= 50 ? 'Second Class' : 'Pass Class';
  document.getElementById('sgpa-cgpa').textContent = cgpa.toFixed(2);
  document.getElementById('sgpa-pct').textContent = pct.toFixed(2) + '%';
  document.getElementById('sgpa-class').textContent = cls;
  document.getElementById('sgpa-count').textContent = count;
  document.getElementById('sgpa-result').classList.add('show');
}
function updateRatioInputs() {
  const mode = document.getElementById('ratio-mode').value;
  const c = document.getElementById('ratio-inputs');
  if (mode === 'divide') c.innerHTML = `<div class="two-col"><div class="form-row"><label>Total Amount (₹)</label><input type="number" id="rat-a" value="120000" min="1"></div><div class="form-row"><label>Ratio (e.g. 3:2:1)</label><input type="text" id="rat-b" value="3:2:1" placeholder="e.g. 3:2 or 3:2:1"></div></div>`;
  else if (mode === 'proportion') c.innerHTML = `<div class="two-col"><div class="form-row"><label>a</label><input type="number" id="rat-a" value="3"></div><div class="form-row"><label>b</label><input type="number" id="rat-b" value="4"></div></div><div class="two-col"><div class="form-row"><label>c</label><input type="number" id="rat-c" value="9"></div><div class="form-row"><label>d = ?</label><input type="text" id="rat-d" value="?" disabled style="background:var(--surface);color:var(--muted)"></div></div>`;
  else c.innerHTML = `<div class="form-row" style="max-width:240px"><label>Ratio to Simplify (e.g. 24:36)</label><input type="text" id="rat-a" value="24:36" placeholder="e.g. 24:36 or 45:30:15"></div>`;
}
function gcd(a,b) { return b===0?a:gcd(b,a%b); }
function calcRatio() {
  const mode = document.getElementById('ratio-mode').value;
  if (mode === 'divide') {
    const total = parseFloat(document.getElementById('rat-a').value);
    const parts = document.getElementById('rat-b').value.split(':').map(Number);
    const sum = parts.reduce((a,b)=>a+b,0);
    const shares = parts.map(p => (p/sum*total).toFixed(2));
    document.getElementById('ratio-out').textContent = '₹' + shares[0];
    document.getElementById('ratio-extras').innerHTML = shares.map((s,i)=>`<div class="result-item"><div class="result-item-label">Share ${i+1} (ratio ${parts[i]})</div><div class="result-item-val">₹${parseFloat(s).toLocaleString('en-IN')}</div></div>`).join('');
  } else if (mode === 'proportion') {
    const a = parseFloat(document.getElementById('rat-a').value);
    const b = parseFloat(document.getElementById('rat-b').value);
    const c = parseFloat(document.getElementById('rat-c').value);
    const d = b * c / a;
    document.getElementById('ratio-out').textContent = d.toFixed(4);
    document.getElementById('ratio-extras').innerHTML = `<div class="result-item"><div class="result-item-label">Proportion</div><div class="result-item-val">${a}:${b} = ${c}:${d.toFixed(4)}</div></div>`;
  } else {
    const parts = document.getElementById('rat-a').value.split(':').map(Number);
    let g = parts[0];
    for (let i = 1; i < parts.length; i++) g = gcd(g, parts[i]);
    const simplified = parts.map(p => p/g).join(' : ');
    document.getElementById('ratio-out').textContent = simplified;
    document.getElementById('ratio-extras').innerHTML = `<div class="result-item"><div class="result-item-label">Original</div><div class="result-item-val">${parts.join(':')}</div></div><div class="result-item"><div class="result-item-label">GCD</div><div class="result-item-val">${g}</div></div>`;
  }
  document.getElementById('ratio-result').classList.add('show');
}
function calcRoman() {
  const mode = document.getElementById('roman-mode').value;
  const input = document.getElementById('roman-input').value.trim();
  const toRomanMap = [[1000,'M'],[900,'CM'],[500,'D'],[400,'CD'],[100,'C'],[90,'XC'],[50,'L'],[40,'XL'],[10,'X'],[9,'IX'],[5,'V'],[4,'IV'],[1,'I']];
  const fromRomanMap = {I:1,V:5,X:10,L:50,C:100,D:500,M:1000};
  if (mode === 'toRoman') {
    let n = parseInt(input);
    if (isNaN(n)||n<1||n>3999){alert('Enter a number between 1 and 3999');return;}
    let result=''; toRomanMap.forEach(([v,s])=>{while(n>=v){result+=s;n-=v;}});
    document.getElementById('roman-out').textContent = result;
  } else {
    let s = input.toUpperCase(), n = 0;
    for (let i=0;i<s.length;i++) {
      const cur=fromRomanMap[s[i]]||0, nxt=fromRomanMap[s[i+1]]||0;
      n += cur < nxt ? -cur : cur;
    }
    document.getElementById('roman-out').textContent = isNaN(n)||n<=0?'Invalid Roman numeral':n;
  }
  document.getElementById('roman-result').classList.add('show');
}
function calcBillSplit() {
  const total = parseFloat(document.getElementById('bs-total').value);
  const people = parseInt(document.getElementById('bs-people').value);
  const tipPct = parseFloat(document.getElementById('bs-tip').value);
  const tipAmt = total * tipPct / 100;
  const grand = total + tipAmt;
  const each = grand / people;
  document.getElementById('bs-each').textContent = '₹' + each.toFixed(2);
  document.getElementById('bs-bill').textContent = '₹' + total.toFixed(2);
  document.getElementById('bs-tipamt').textContent = '₹' + tipAmt.toFixed(2);
  document.getElementById('bs-grand').textContent = '₹' + grand.toFixed(2);
  document.getElementById('bs-tipeach').textContent = '₹' + (tipAmt/people).toFixed(2);
  document.getElementById('billsplit-result').classList.add('show');
}
function calcTip() {
  const bill = parseFloat(document.getElementById('tip-bill').value);
  const pct = parseFloat(document.getElementById('tip-pct').value);
  const people = parseInt(document.getElementById('tip-people').value);
  const tipAmt = bill * pct / 100;
  const total = bill + tipAmt;
  document.getElementById('tip-amount').textContent = '₹' + tipAmt.toFixed(2);
  document.getElementById('tip-total').textContent = '₹' + total.toFixed(2);
  document.getElementById('tip-each').textContent = '₹' + (total/people).toFixed(2);
  document.getElementById('tip-tipeach').textContent = '₹' + (tipAmt/people).toFixed(2);
  document.getElementById('tip-result').classList.add('show');
}
function calcSleep() {
  const mode = document.getElementById('sleep-mode').value;
  const [h,m] = document.getElementById('sleep-time').value.split(':').map(Number);
  const base = h*60+m;
  const onset = 15;
  const cycle = 90;
  const fmt = mins => { const hh=Math.floor(((mins%1440)+1440)%1440/60), mm=((mins%1440)+1440)%1440%60; return `${String(hh).padStart(2,'0')}:${String(mm).padStart(2,'0')}`; };
  let times = [];
  if (mode === 'bedtime') {
    // wake at base, find bedtimes for 4-6 cycles
    for (let c=6;c>=4;c--) times.push({cycles:c, time:fmt(base-onset-c*cycle), hrs:(c*1.5).toFixed(1)});
    document.getElementById('sleep-best').textContent = times[0].time;
  } else {
    // sleep at base, find wake times for 4-6 cycles
    for (let c=4;c<=6;c++) times.push({cycles:c, time:fmt(base+onset+c*cycle), hrs:(c*1.5).toFixed(1)});
    document.getElementById('sleep-best').textContent = times[0].time;
  }
  document.getElementById('sleep-options').innerHTML = times.map(t=>`⏰ <strong>${t.time}</strong> — ${t.cycles} cycles (${t.hrs} hrs)`).join('<br>');
  document.getElementById('sleep-result').classList.add('show');
}
function calcWater() {
  const wt = parseFloat(document.getElementById('wat-wt').value);
  const exercise = parseInt(document.getElementById('wat-exercise').value);
  const climate = document.getElementById('wat-climate').value;
  const base = wt * 35;
  const exerciseExtra = exercise / 30 * 500;
  const climateExtra = climate==='hot'?500:climate==='very_hot'?1000:0;
  const total = base + exerciseExtra + climateExtra;
  const litres = (total/1000).toFixed(2);
  document.getElementById('wat-litres').textContent = litres + ' L/day';
  document.getElementById('wat-glasses').textContent = Math.round(total/250) + ' glasses';
  document.getElementById('wat-base').textContent = (base/1000).toFixed(2) + ' L';
  document.getElementById('wat-extra').textContent = ((exerciseExtra+climateExtra)/1000).toFixed(2) + ' L';
  document.getElementById('water-result').classList.add('show');
}
function calcElectricity() {
  const units = parseFloat(document.getElementById('elec-units').value);
  const r1 = parseFloat(document.getElementById('elec-r1').value);
  const r2 = parseFloat(document.getElementById('elec-r2').value);
  const r3 = parseFloat(document.getElementById('elec-r3').value);
  const r4 = parseFloat(document.getElementById('elec-r4').value);
  const fixed = parseFloat(document.getElementById('elec-fixed').value);
  const duty = parseFloat(document.getElementById('elec-duty').value) / 100;
  let energy = 0;
  if (units <= 100) energy = units * r1;
  else if (units <= 200) energy = 100*r1 + (units-100)*r2;
  else if (units <= 400) energy = 100*r1 + 100*r2 + (units-200)*r3;
  else energy = 100*r1 + 100*r2 + 200*r3 + (units-400)*r4;
  const dutyAmt = (energy + fixed) * duty;
  const total = energy + fixed + dutyAmt;
  document.getElementById('elec-total').textContent = '₹' + total.toFixed(2);
  document.getElementById('elec-energy').textContent = '₹' + energy.toFixed(2);
  document.getElementById('elec-fixedout').textContent = '₹' + fixed.toFixed(2);
  document.getElementById('elec-dutyout').textContent = '₹' + dutyAmt.toFixed(2);
  document.getElementById('elec-perunit').textContent = '₹' + (total/units).toFixed(2) + '/unit';
  document.getElementById('electricity-result').classList.add('show');
}
function calcPregnancy() {
  const lmp = new Date(document.getElementById('preg-lmp').value);
  const edd = new Date(lmp.getTime() + 280*24*3600000);
  const today = new Date();
  const daysPreg = Math.floor((today - lmp) / (24*3600000));
  const weeksPreg = Math.floor(daysPreg / 7);
  const conception = new Date(lmp.getTime() + 14*24*3600000);
  const daysLeft = Math.max(0, Math.floor((edd - today)/(24*3600000)));
  const trimester = weeksPreg < 13 ? '1st Trimester (Weeks 1–13)' : weeksPreg < 27 ? '2nd Trimester (Weeks 14–26)' : '3rd Trimester (Weeks 27–40)';
  const fmtDate = d => d.toLocaleDateString('en-IN', {day:'numeric',month:'long',year:'numeric'});
  document.getElementById('preg-edd').textContent = fmtDate(edd);
  document.getElementById('preg-week').textContent = `Week ${weeksPreg} of 40`;
  document.getElementById('preg-trimester').textContent = trimester;
  document.getElementById('preg-conception').textContent = fmtDate(conception);
  document.getElementById('preg-days').textContent = daysLeft + ' days';
  document.getElementById('pregnancy-result').classList.add('show');
}
const CUR_RATES = { INR:1, USD:0.01191, EUR:0.01096, GBP:0.00934, AED:0.04370, SGD:0.01600, AUD:0.01870, CAD:0.01650, JPY:1.788 };
function calcCurrency() {
  const amt = parseFloat(document.getElementById('cur-amt').value);
  const from = document.getElementById('cur-from').value;
  const to = document.getElementById('cur-to').value;
  const inINR = amt / CUR_RATES[from];
  const result = inINR * CUR_RATES[to];
  const rate = CUR_RATES[to] / CUR_RATES[from];
  const bankResult = result * (to === 'INR' ? 0.98 : 1.02);
  document.getElementById('cur-out').textContent = result.toFixed(4) + ' ' + to;
  document.getElementById('cur-rate').textContent = '1 ' + from + ' ≈ ' + rate.toFixed(4) + ' ' + to;
  document.getElementById('cur-bank').textContent = bankResult.toFixed(4) + ' ' + to;
  document.getElementById('currency-result').classList.add('show');
}
function numToWordsIndian(n) {
  if (n === 0) return 'Zero';
  const ones = ['','One','Two','Three','Four','Five','Six','Seven','Eight','Nine','Ten','Eleven','Twelve','Thirteen','Fourteen','Fifteen','Sixteen','Seventeen','Eighteen','Nineteen'];
  const tens = ['','','Twenty','Thirty','Forty','Fifty','Sixty','Seventy','Eighty','Ninety'];
  function twoDigit(n) {
    if (n < 20) return ones[n];
    return tens[Math.floor(n/10)] + (n%10 ? ' ' + ones[n%10] : '');
  }
  function threeDigit(n) {
    if (n < 100) return twoDigit(n);
    return ones[Math.floor(n/100)] + ' Hundred' + (n%100 ? ' ' + twoDigit(n%100) : '');
  }
  let result = '';
  if (n >= 10000000) { result += twoDigit(Math.floor(n/10000000)) + ' Crore '; n %= 10000000; }
  if (n >= 100000) { result += twoDigit(Math.floor(n/100000)) + ' Lakh '; n %= 100000; }
  if (n >= 1000) { result += twoDigit(Math.floor(n/1000)) + ' Thousand '; n %= 1000; }
  if (n > 0) result += threeDigit(n);
  return result.trim();
}
function numToWordsIntl(n) {
  if (n === 0) return 'Zero';
  const ones = ['','One','Two','Three','Four','Five','Six','Seven','Eight','Nine','Ten','Eleven','Twelve','Thirteen','Fourteen','Fifteen','Sixteen','Seventeen','Eighteen','Nineteen'];
  const tens = ['','','Twenty','Thirty','Forty','Fifty','Sixty','Seventy','Eighty','Ninety'];
  function twoDigit(n) { return n<20?ones[n]:tens[Math.floor(n/10)]+(n%10?' '+ones[n%10]:''); }
  function threeDigit(n) { return n<100?twoDigit(n):ones[Math.floor(n/100)]+' Hundred'+(n%100?' '+twoDigit(n%100):''); }
  let result='', orig=n;
  if (n>=1000000000){result+=threeDigit(Math.floor(n/1000000000))+' Billion ';n%=1000000000;}
  if (n>=1000000){result+=threeDigit(Math.floor(n/1000000))+' Million ';n%=1000000;}
  if (n>=1000){result+=threeDigit(Math.floor(n/1000))+' Thousand ';n%=1000;}
  if (n>0) result+=threeDigit(n);
  return result.trim();
}
function calcNumWords() {
  const n = parseInt(document.getElementById('nw-num').value);
  if (isNaN(n)||n<0){alert('Enter a valid positive number');return;}
  document.getElementById('nw-indian').textContent = numToWordsIndian(n) + ' only';
  document.getElementById('nw-intl').textContent = numToWordsIntl(n) + ' only';
  document.getElementById('numwords-result').classList.add('show');
}
function updateAreaInputs() {
  const shape = document.getElementById('area-shape').value;
  const c = document.getElementById('area-inputs');
  if (shape === 'rect') c.innerHTML = `<div class="two-col"><div class="form-row"><label>Length (feet)</label><input type="number" id="area-a" value="20" step="0.1"></div><div class="form-row"><label>Width (feet)</label><input type="number" id="area-b" value="15" step="0.1"></div></div>`;
  else if (shape === 'circle') c.innerHTML = `<div class="form-row" style="max-width:200px"><label>Radius (feet)</label><input type="number" id="area-a" value="10" step="0.1"></div>`;
  else if (shape === 'triangle') c.innerHTML = `<div class="two-col"><div class="form-row"><label>Base (feet)</label><input type="number" id="area-a" value="20" step="0.1"></div><div class="form-row"><label>Height (feet)</label><input type="number" id="area-b" value="15" step="0.1"></div></div>`;
  else c.innerHTML = `<div class="two-col"><div class="form-row"><label>Parallel Side a (feet)</label><input type="number" id="area-a" value="20" step="0.1"></div><div class="form-row"><label>Parallel Side b (feet)</label><input type="number" id="area-b" value="15" step="0.1"></div></div><div class="form-row" style="max-width:200px"><label>Height (feet)</label><input type="number" id="area-h" value="10" step="0.1"></div>`;
}
function calcArea() {
  const shape = document.getElementById('area-shape').value;
  const a = parseFloat(document.getElementById('area-a').value);
  const b = parseFloat((document.getElementById('area-b')||{}).value)||0;
  const h = parseFloat((document.getElementById('area-h')||{}).value)||0;
  let sqft;
  if (shape==='rect') sqft = a*b;
  else if (shape==='circle') sqft = Math.PI*a*a;
  else if (shape==='triangle') sqft = 0.5*a*b;
  else sqft = 0.5*(a+b)*h;
  document.getElementById('area-sqft').textContent = sqft.toFixed(2) + ' sq ft';
  document.getElementById('area-sqm').textContent = (sqft*0.0929).toFixed(2) + ' sq m';
  document.getElementById('area-sqyard').textContent = (sqft/9).toFixed(2) + ' sq yd';
  document.getElementById('area-cents').textContent = (sqft/435.6).toFixed(4) + ' cents';
  document.getElementById('area-acres').textContent = (sqft/43560).toFixed(6) + ' acres';
  document.getElementById('area-result').classList.add('show');
}

function copyResult(id) {
  const rb = document.getElementById(`${id}-result`);
  if (!rb) return;
  const text = Array.from(rb.querySelectorAll('.result-value, .result-item-val')).map(el => el.textContent).join(' | ');
  navigator.clipboard.writeText(text).then(() => { const btn = rb.querySelector('.copy-btn'); btn.textContent = '✅ Copied!'; setTimeout(()=>btn.textContent='📋 Copy Result',2000); });
}

// Init
renderHomeTools(TOOLS);
</script>
</body>
</html>
